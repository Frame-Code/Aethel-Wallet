# ── Servidor ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=3600s
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# ── Firebase Admin SDK ─────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── RPC Providers ──────────────────────────────────────────────
HELIUS_API_KEY=
HELIUS_RPC_URL=
QUICKNODE_BTC_URL=
QUICKNODE_BNB_URL=
ANKR_API_KEY=

# ── Webhooks (secrets para verificar HMAC) ─────────────────────
HELIUS_WEBHOOK_SECRET=
QUICKNODE_WEBHOOK_SECRET=

# ── CoinGecko ─────────────────────────────────────────────────
COINGECKO_API_KEY=
COINSTATS_API_KEY=

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
