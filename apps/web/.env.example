# ─────────────────────────────────────────
# FIREBASE CLIENT
# Obtener en: Firebase Console → Configuración del proyecto → Tus apps
# ─────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=              # API Key pública de Firebase
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=          # ej: mi-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=           # ID del proyecto Firebase
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=       # ej: mi-app.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=  # ID del remitente para notificaciones
NEXT_PUBLIC_FIREBASE_APP_ID=              # ID de la app web en Firebase
NEXT_PUBLIC_FIREBASE_VAPID_KEY=           # Clave VAPID para push notifications

# ─────────────────────────────────────────
# FIREBASE APP CHECK
# Obtener en: Firebase Console → App Check → reCAPTCHA Enterprise
# ─────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=           # Site key de reCAPTCHA v3

# ─────────────────────────────────────────
# BACKEND API
# ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/v1  # URL base de la API (cambiar en producción)

# ─────────────────────────────────────────
# RPC PROVIDERS (acceso directo desde el frontend)
# ─────────────────────────────────────────
NEXT_PUBLIC_HELIUS_RPC_URL=               # URL RPC de Helius para Solana
NEXT_PUBLIC_ALCHEMY_BTC_URL=              # URL RPC de Alchemy para Bitcoin
NEXT_PUBLIC_ALCHEMY_BNB_URL=             # URL RPC de Alchemy para BNB Chain

# ─────────────────────────────────────────
# WALLETCONNECT
# Obtener en: https://cloud.walletconnect.com
# ─────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=     # Project ID de WalletConnect Cloud